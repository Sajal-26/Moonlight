{
    "routes": [
        {
            "src": "/api/search",
            "dest": "/api/search.ts"
        },
        {
            "src": "/api/next",
            "dest": "/api/next.ts"
        },
        {
            "src": "/api/lyrics",
            "dest": "/api/lyrics.ts"
        },
        {
            "src": "/api/stream",
            "dest": "/api/stream.ts",
            "headers": {
                "cache-control": "s-maxage=3600, stale-while-revalidate"
            }
        }
    ]
}