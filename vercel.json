{
    "routes": [
        {
            "src": "/api/stream",
            "dest": "/api/stream.ts",
            "headers": {
                "Access-Control-Allow-Origin": "*",
                "Access-Control-Allow-Methods": "GET, OPTIONS",
                "Access-Control-Allow-Headers": "Content-Type",
                "Cache-Control": "s-maxage=3600, stale-while-revalidate"
            }
        },
        {
            "src": "/api/search",
            "dest": "/api/search.ts"
        },
        {
            "src": "/api/next",
            "dest": "/api/next.ts"
        },
        {
            "src": "/api/lyrics",
            "dest": "/api/lyrics.ts"
        }
    ]
}